from itertools import combinations

# Read input values
n = int(input())
letters = input().split()
k = int(input())

# Generate all possible index combinations of size k
combos = list(combinations(range(n), k))

# Count combinations that contain at least one index pointing to 'a'
# Use 0-based indexing as generated by range(n)
favorable = 0
for c in combos:
    if any(letters[i] == 'a' for i in c):
        favorable += 1

# Calculate and print probability rounded to 4 decimal places
print(f"{favorable / len(combos):.4f}")
