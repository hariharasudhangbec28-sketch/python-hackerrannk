from datetime import datetime

def time_delta(t1, t2):
    # This format matches: Day dd Mon yyyy hh:mm:ss +xxxx
    time_format = '%a %d %b %Y %H:%M:%S %z'
    
    # Convert strings to timezone-aware datetime objects
    dt1 = datetime.strptime(t1, time_format)
    dt2 = datetime.strptime(t2, time_format)
    
    # Subtracting two aware datetimes gives a timedelta object
    # total_seconds() converts the difference into seconds
    diff = abs((dt1 - dt2).total_seconds())
    
    return int(diff)

if __name__ == '__main__':
    t = int(input())
    for _ in range(t):
        t1 = input()
        t2 = input()
        print(time_delta(t1, t2))
