from collections import defaultdict

# Read n and m
n, m = map(int, input().split())

# Initialize defaultdict with a list factory
group_a = defaultdict(list)

# Read Group A and store 1-based indices
for i in range(1, n + 1):
    word = input().strip()
    group_a[word].append(str(i))

# Read Group B and check against Group A
for _ in range(m):
    word_b = input().strip()
    
    if word_b in group_a:
        # Join the list of indices with a space
        print(" ".join(group_a[word_b]))
    else:
        # Word not found
        print("-1")
