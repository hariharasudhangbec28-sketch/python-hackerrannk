from collections import OrderedDict

# 1. Initialize the OrderedDict to store word counts
word_counts = OrderedDict()

# 2. Read the number of total words
n = int(input())

for _ in range(n):
    word = input().strip()
    
    # Update the count for each word
    if word in word_counts:
        word_counts[word] += 1
    else:
        word_counts[word] = 1

# 3. Output the number of distinct words
print(len(word_counts))

# 4. Output the occurrences separated by a space
# We extract the values and convert them to strings for joining
print(*(word_counts.values()))
