# 1. Read the main set A
A = set(map(int, input().split()))

# 2. Read the number of other sets
n = int(input())

# 3. Assume it is a strict superset until proven otherwise
is_strict_superset = True

for _ in range(n):
    # Read the next set to compare against A
    other_set = set(map(int, input().split()))
    
    # Check if A is a strict superset of other_set
    # The '>' operator handles both: 
    #   - All elements of other_set are in A
    #   - len(A) > len(other_set)
    if not (A > other_set):
        is_strict_superset = False
        break

# 4. Print the final result
print(is_strict_superset)
