import numpy

# Read the dimension N of the square matrix
n = int(input())

# Read N lines of space-separated elements to form the matrix
# We use float to handle potential decimal inputs
a = numpy.array([input().split() for _ in range(n)], float)

# Use numpy.linalg.det to calculate the determinant
det = numpy.linalg.det(a)

# Round the result to 2 decimal places as per the task requirement
print(round(det, 2))
