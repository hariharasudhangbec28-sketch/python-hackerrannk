def sort_key(c):
    # Category 1: Lowercase letters (Weight 0)
    if c.islower():
        return (0, c)
    # Category 2: Uppercase letters (Weight 1)
    elif c.isupper():
        return (1, c)
    # Category 3: Odd digits (Weight 2)
    elif c.isdigit() and int(c) % 2 != 0:
        return (2, c)
    # Category 4: Even digits (Weight 3)
    else:
        return (3, c)

# 1. Read input string
s = input().strip()

# 2. Sort using the custom key function
# sorted() returns a list, so we join it back into a string
result = "".join(sorted(s, key=sort_key))

print(result)
